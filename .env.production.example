# NextAuth
NEXTAUTH_URL=https://cms.tinten.ai
NEXTAUTH_SECRET=CHANGE_ME_RANDOM_32_CHARS
# Auth.js v5/Vercel templates sometimes use AUTH_SECRET; keep it equal to NEXTAUTH_SECRET if used.
AUTH_SECRET=CHANGE_ME_RANDOM_32_CHARS

# tinnten-server API (internal docker network)
NEXT_PUBLIC_BACKEND_URL=http://tinnten-server:5001/api/v10

# Storage (DigitalOcean Spaces) - profil fotoğrafı için, opsiyonel
STORAGE_TYPE=digitalocean
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION=ams3
STORAGE_BUCKET=
STORAGE_ENDPOINT=
STORAGE_CDN_URL=

# SMTP - şifre sıfırlama vs. opsiyonel
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@tinten.ai
